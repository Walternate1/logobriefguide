---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description?: string;
  pathname?: string;
  noindex?: boolean;
}

const { title, description, pathname = "/", noindex = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <SEOHead
      title={title}
      description={description}
      pathname={pathname}
      noindex={noindex}
    />
    <style is:global>
      :root {
        --bg: #ffffff;
        --surface: #f8fafc;
        --text: #111827;
        --muted: #6b7280;
        --line: #e5e7eb;
        --accent: #111827;
        --max: 1100px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: inherit; }
      img { max-width: 100%; height: auto; }
      .wrap {
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 20px;
      }
      .site-header {
        border-bottom: 1px solid var(--line);
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
      }
      .site-header .wrap,
      .site-footer .wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding-top: 18px;
        padding-bottom: 18px;
      }
      .site-footer {
        border-top: 1px solid var(--line);
        margin-top: 64px;
      }
      .brand {
        font-weight: 800;
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      nav ul,
      .site-footer ul {
        display: flex;
        gap: 16px;
        list-style: none;
        margin: 0;
        padding: 0;
        flex-wrap: wrap;
      }
      nav a,
      .site-footer a {
        text-decoration: none;
      }
      main { padding: 48px 0; }
      h1, h2, h3 { line-height: 1.12; letter-spacing: -0.03em; }
      h1 { font-size: clamp(2.25rem, 6vw, 4rem); margin: 0 0 18px; }
      h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); margin: 0 0 14px; }
      h3 { font-size: 1.15rem; margin: 0 0 10px; }
      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 8px;
      }
      .button,
      .button-secondary {
        display: inline-block;
        padding: 12px 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
      }
      .button {
        background: var(--text);
        color: white;
        border: 1px solid var(--text);
      }
      .button-secondary {
        border: 1px solid var(--line);
        background: white;
      }
      .button-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
      }
      .hero {
        padding: 24px 0 36px;
      }
      .hero p.lead {
        max-width: 760px;
        font-size: 1.15rem;
        color: #374151;
      }
      .section {
        padding: 32px 0;
      }
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
      }
      .card {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 22px;
        background: white;
      }
      .soft-card {
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 24px;
        background: var(--surface);
      }
      .prose {
        max-width: 760px;
      }
      .prose ul, .prose ol {
        padding-left: 20px;
      }
      .two-col {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 24px;
      }
      .checklist {
        margin: 0;
        padding-left: 20px;
      }
      .footer-brand {
        margin: 0 0 4px;
        font-weight: 700;
      }
      .footer-note {
        margin: 0;
        color: var(--muted);
        max-width: 340px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th, td {
        text-align: left;
        padding: 12px;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }
      @media (max-width: 800px) {
        .two-col {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
