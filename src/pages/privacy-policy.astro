---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Privacy Policy | Logo Brief Guide" pathname="/privacy-policy/">
  <section class="prose">
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p>
      This starter includes a placeholder privacy page. Replace this with your
      final privacy policy before launch.
    </p>
    <p>
      At minimum, explain what analytics tools you use, whether affiliate links
      are present, what contact data may be collected, and how a visitor can
      reach you with privacy questions.
    </p>
  </section>
</MainLayout>
